ENVIRONMENT=production
APP_NAME=College Admission Agent
CORS_ORIGINS=*

# JWT (optional for now; app uses a dev default if empty)
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS S3
AWS_S3_BUCKET=your-s3-bucket
AWS_REGION=us-east-1
AWS_S3_PREFIX=vu-chatbot-db
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_SESSION_TOKEN=

# IBM Watsonx / Granite (optional for now)
IBM_CLOUD_API_KEY=
IBM_PROJECT_ID=
IBM_WATSONX_URL=
GRANITE_EMBEDDING_MODEL=
GRANITE_CHAT_MODEL=
